---
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <ClientRouter />
    <script
      is:inline
      src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.11.3/p5.min.js"
    ></script>
  </head>
  <body>
    <main>
      <div id="hero" transition:persist></div>
      <div class="hero-content">
        <Header />
        <div class="container">
          <slot />
        </div>
      </div>
    </main>
    <!-- <Footer /> -->
  </body>
</html>

<script is:inline>
  if (!window.__sketchRunning) {
    window.__sketchRunning = true;

    new p5(function (p) {
      const COUNT = 300;
      const NOISE_SCALE = 0.003;
      let particles = [];

      class Particle {
        constructor() {
          this.respawn(true);
        }

        respawn(anywhere) {
          this.x = p.random(p.width);
          this.y = anywhere ? p.random(p.height) : p.random(p.height);
          this.px = this.x;
          this.py = this.y;
          this.speed = p.random(1, 2.5);
          this.hue = p.random(235, 235);
          this.life = p.random(120, 320);
          this.maxLife = this.life;
        }

        update() {
          this.px = this.x;
          this.py = this.y;
          const angle =
            p.noise(
              this.x * NOISE_SCALE,
              this.y * NOISE_SCALE,
              p.frameCount * 0.004,
            ) *
            p.TWO_PI *
            2;
          this.x += p.cos(angle) * this.speed;
          this.y += p.sin(angle) * this.speed;
          this.life--;

          if (
            this.life <= 0 ||
            this.x < 0 ||
            this.x > p.width ||
            this.y < 0 ||
            this.y > p.height
          ) {
            this.respawn(false);
          }
        }

        draw() {
          const alpha = (this.life / this.maxLife) * 100;
          p.stroke(this.hue, 86, 100, alpha);
          p.strokeWeight(1.2);
          p.line(this.px, this.py, this.x, this.y);
        }
      }

      p.setup = function () {
        const hero = document.getElementById('hero');
        const cnv = p.createCanvas(hero.clientWidth, hero.clientHeight);
        cnv.parent('hero');
        p.colorMode(p.HSB, 360, 100, 100, 100);
        p.background(0, 0, 6);
        for (let i = 0; i < COUNT; i++) particles.push(new Particle());

        new ResizeObserver(([entry]) => {
          const { width, height } = entry.contentRect;
          p.resizeCanvas(width, height);
        }).observe(hero);
      };

      p.draw = function () {
        p.background(0, 0, 6, 2);
        for (const pt of particles) {
          pt.update();
          pt.draw();
        }
      };
    });
  }
</script>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    height: 100%;
  }

  :global(body) {
    display: flex;
    flex-direction: column;
  }

  main {
    position: relative;
    min-height: 100vh;
    width: 100%;
  }

  #hero {
    position: absolute;
    inset: 0;
    background: hsl(0, 0%, 6%);
    overflow: hidden;
  }

  #hero canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero-content {
    position: absolute;
    z-index: 1;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    height: 90%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: start;
    background-color: black;
    overflow-y: auto;
    opacity: 70%;
    border-radius: 10px;
  }

  .container {
    padding: 1em 10em;
  }
</style>
