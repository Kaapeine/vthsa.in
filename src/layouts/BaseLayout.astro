---
import { ClientRouter } from 'astro:transitions';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <ClientRouter />
  </head>
  <body>
    <main>
      <div id="hero" transition:persist></div>
      <div class="hero-content">
        <Header />
        <div class="container">
          <slot />
        </div>
      </div>
    </main>
    <!-- <Footer /> -->
    <!-- <div id="yt-player" transition:persist>
      <button id="yt-close" aria-label="Close">✕</button>
      <iframe
        src="https://www.youtube.com/embed/rCQqCOu1qWs?autoplay=1&mute=1&enablejsapi=1"
        allow="autoplay; encrypted-media"
        allowfullscreen></iframe>
    </div> -->
  </body>
</html>

<script is:inline>
  // if (!window.__ytCloseWired) {
  //   window.__ytCloseWired = true;
  //   document.getElementById('yt-close').addEventListener('click', () => {
  //     const player = document.getElementById('yt-player');
  //     const iframe = player.querySelector('iframe');
  //     if (iframe) iframe.src = '';
  //     player.style.display = 'none';
  //   });
  // }

  if (!window.__sketchRunning) {
    window.__sketchRunning = true;

    const _p5Script = document.createElement('script');
    _p5Script.src =
      'https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.11.3/p5.min.js';
    _p5Script.onload = function () {
      runSketch();
    };
    document.head.appendChild(_p5Script);

    function runSketch() {
      new p5(function (p) {
        const COUNT = 300;
        const NOISE_SCALE = 0.003;
        let particles = [];

        class Particle {
          constructor() {
            this.respawn(true);
          }

          respawn(anywhere) {
            this.x = p.random(p.width);
            this.y = anywhere ? p.random(p.height) : p.random(p.height);
            this.px = this.x;
            this.py = this.y;
            this.speed = p.random(1, 2.5);
            this.hue = p.random(220, 240);
            this.life = p.random(120, 320);
            this.maxLife = this.life;
          }

          update() {
            this.px = this.x;
            this.py = this.y;
            const angle =
              p.noise(
                this.x * NOISE_SCALE,
                this.y * NOISE_SCALE,
                p.frameCount * 0.004,
              ) *
              p.TWO_PI *
              2;
            this.x += p.cos(angle) * this.speed;
            this.y += p.sin(angle) * this.speed;
            this.life--;

            if (
              this.life <= 0 ||
              this.x < 0 ||
              this.x > p.width ||
              this.y < 0 ||
              this.y > p.height
            ) {
              this.respawn(false);
            }
          }

          draw() {
            const alpha = (this.life / this.maxLife) * 100;
            p.stroke(this.hue, 86, 100, alpha);
            p.strokeWeight(1.2);
            p.line(this.px, this.py, this.x, this.y);
          }
        }

        p.setup = function () {
          const hero = document.getElementById('hero');
          const cnv = p.createCanvas(hero.clientWidth, hero.clientHeight);
          cnv.parent('hero');
          p.colorMode(p.HSB, 360, 100, 100, 100);
          p.background(0, 0, 6);
          for (let i = 0; i < COUNT; i++) particles.push(new Particle());

          new ResizeObserver(([entry]) => {
            const { width, height } = entry.contentRect;
            p.resizeCanvas(width, height);
          }).observe(hero);
        };

        p.draw = function () {
          p.background(0, 0, 6, 2);
          for (const pt of particles) {
            pt.update();
            pt.draw();
          }
        };
      });
    }
  }
</script>

<style>
  :global(html),
  :global(body) {
    margin: 0;
    padding: 0;
    height: 100%;
  }

  :global(body) {
    display: flex;
    flex-direction: column;
  }

  main {
    position: relative;
    min-height: 100vh;
    width: 100%;
  }

  #hero {
    position: absolute;
    inset: 0;
    background: color(rgb 0 0 6);
    overflow: hidden;
  }

  #hero canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  .hero-content {
    position: absolute;
    z-index: 1;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    height: 90%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: start;
    background-color: rgba(0, 0, 0, 0.7);
    overflow-x: hidden;
    /* backdrop-filter: blur(2px); */
    border-radius: 10px;
    border: 1px solid var(--accent-dark);
  }

  @media (max-width: 720px) {
    .hero-content {
      width: 100%;
      height: 100%;
      border: 0px;
    }
  }

  .container {
    padding: 1rem clamp(1rem, 6vw, 5rem);
    width: 100%;
    overflow-y: auto;
  }

  #yt-player {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    width: 280px;
    aspect-ratio: 16 / 9;
    z-index: 100;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.6);
  }

  #yt-player iframe {
    width: 100%;
    height: 100%;
    border: none;
    display: block;
  }

  #yt-close {
    position: absolute;
    top: 0.3rem;
    right: 0.3rem;
    z-index: 101;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    border: none;
    border-radius: 50%;
    width: 1.4rem;
    height: 1.4rem;
    font-size: 0.7rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
