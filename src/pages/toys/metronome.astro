---
import ToyLayout from '../../layouts/ToyLayout.astro';

// --- geometry (SVG viewBox is 300 x 480) ---
const PIVOT_X = 150;
const SCALE_TOP_Y = 60; // weight position for the slowest tempo
const SCALE_BOT_Y = 335; // weight position for the fastest tempo
const BPM_MIN = 40;
const BPM_MAX = 208;

const yForBpm = (bpm: number) =>
  SCALE_TOP_Y +
  ((bpm - BPM_MIN) / (BPM_MAX - BPM_MIN)) * (SCALE_BOT_Y - SCALE_TOP_Y);

// Body trapezium edges, so ticks/panel can follow the taper.
const BODY_TOP_Y = 30;
const BODY_BOT_Y = 440;
const edgeX = (y: number, side: -1 | 1) => {
  const topHalf = 64;
  const botHalf = 122;
  const t = (y - BODY_TOP_Y) / (BODY_BOT_Y - BODY_TOP_Y);
  const half = topHalf + (botHalf - topHalf) * t;
  return PIVOT_X + side * half;
};

// The classic Maelzel scale: steps widen toward the fast (bottom) end, so the
// markers bunch up toward the slow (top) end. Built top-value-down.
const scaleBpms: number[] = [208];
let _v = 208;
while (_v > 144) {
  _v -= 8;
  scaleBpms.push(_v);
} // 200..144 by 8
while (_v > 120) {
  _v -= 6;
  scaleBpms.push(_v);
} // 138..120 by 6
while (_v > 72) {
  _v -= 4;
  scaleBpms.push(_v);
} //  116..72 by 4
while (_v > 60) {
  _v -= 3;
  scaleBpms.push(_v);
} //   69..60 by 3
while (_v > 40) {
  _v -= 2;
  scaleBpms.push(_v);
} //   58..40 by 2
// Alternate sides: 208 left, 200 right, 192 left, …
const marks = scaleBpms.map((bpm, i) => ({
  bpm,
  side: (i % 2 === 0 ? -1 : 1) as -1 | 1,
}));

// Italian tempo zones, anchored at a representative bpm
const zones = [
  { name: 'Largo', bpm: 50 },
  { name: 'Adagio', bpm: 70 },
  { name: 'Andante', bpm: 92 },
  { name: 'Moderato', bpm: 114 },
  { name: 'Allegro', bpm: 150 },
  { name: 'Presto', bpm: 188 },
];

// base panel trapezoid (hides the pivot + lower rod)
const PANEL_TOP_Y = 345;
const panelPts = [
  [edgeX(PANEL_TOP_Y, -1), PANEL_TOP_Y],
  [edgeX(PANEL_TOP_Y, 1), PANEL_TOP_Y],
  [edgeX(BODY_BOT_Y, 1), BODY_BOT_Y],
  [edgeX(BODY_BOT_Y, -1), BODY_BOT_Y],
]
  .map((p) => p.join(','))
  .join(' ');

const bodyPts = [
  [edgeX(BODY_TOP_Y, -1), BODY_TOP_Y],
  [edgeX(BODY_TOP_Y, 1), BODY_TOP_Y],
  [edgeX(BODY_BOT_Y, 1), BODY_BOT_Y],
  [edgeX(BODY_BOT_Y, -1), BODY_BOT_Y],
]
  .map((p) => p.join(','))
  .join(' ');

// little pyramid cap on top, base flush with the body top edge
const capPts = [
  [edgeX(BODY_TOP_Y, -1), BODY_TOP_Y],
  [edgeX(BODY_TOP_Y, 1), BODY_TOP_Y],
  [PIVOT_X, 6],
]
  .map((p) => p.join(','))
  .join(' ');

// Double-edged wood frame around the top (scale) half: a tapered band that
// follows the body edges from the cap down to the base panel, with the scale
// showing through the window.
const FRAME_TOP_Y = BODY_TOP_Y; // 30
const FRAME_BOT_Y = PANEL_TOP_Y; // 345
const FW = 9; // frame band width
const outerFrame = [
  [edgeX(FRAME_TOP_Y, -1), FRAME_TOP_Y],
  [edgeX(FRAME_TOP_Y, 1), FRAME_TOP_Y],
  [edgeX(FRAME_BOT_Y, 1), FRAME_BOT_Y],
  [edgeX(FRAME_BOT_Y, -1), FRAME_BOT_Y],
];
// Inner ring meets the outer ring at BOTH the top and bottom, so the band is
// just the two side rails — no top or bottom bar.
const innerFrame = [
  [edgeX(FRAME_TOP_Y, -1) + FW, FRAME_TOP_Y],
  [edgeX(FRAME_TOP_Y, 1) - FW, FRAME_TOP_Y],
  [edgeX(FRAME_BOT_Y, 1) - FW, FRAME_BOT_Y],
  [edgeX(FRAME_BOT_Y, -1) + FW, FRAME_BOT_Y],
];
const toPts = (a: number[][]) => a.map((p) => p.join(',')).join(' ');
// evenodd path: outer ring minus inner ring = the frame band (the hole is the
// window the scale shows through).
const framePath =
  'M ' +
  outerFrame.map((p) => p.join(' ')).join(' L ') +
  ' Z M ' +
  innerFrame.map((p) => p.join(' ')).join(' L ') +
  ' Z';
// Inner bevel as two separate vertical lines (left + right rail inner edges),
// so no edge is drawn across the top or bottom.
const bevelLeftPts = toPts([innerFrame[0], innerFrame[3]]);
const bevelRightPts = toPts([innerFrame[1], innerFrame[2]]);
---

<ToyLayout
  toyName="Metronome"
  toyHref="/toys/metronome"
  description="An analog-style pendulum metronome, 40–208 BPM."
  align="fill"
>
  <div class="header-wrap" slot="header-actions">
    <span class="instruction"
      >Move weight to set tempo; Drag pendulum to start</span
    >
    <label class="vib">
      <input type="checkbox" id="vib" />
      <span>Vibrate</span>
    </label>
  </div>

  <div class="metronome" id="metronome">
    <div
      class="device"
      id="device"
      role="slider"
      aria-label="Set tempo in beats per minute"
      aria-valuemin={BPM_MIN}
      aria-valuemax={BPM_MAX}
      aria-valuenow="120"
      tabindex="0"
    >
      <!-- Three stacked layers so the animated pendulum sits in its own
           filter-free SVG. The expensive woodgrain (feTurbulence) lives only in
           the static base/panel layers, which are painted once; moving the rod
           never repaints them, keeping the swing smooth (esp. on mobile). -->
      <svg class="dev-layer" viewBox="0 0 300 480" aria-hidden="true">
        <defs>
          <linearGradient id="body" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#0b0b0c"></stop>
            <stop offset="50%" stop-color="#000000"></stop>
            <stop offset="100%" stop-color="#000000"></stop>
          </linearGradient>
          <linearGradient id="panel" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#15181f"></stop>
            <stop offset="50%" stop-color="#23262f"></stop>
            <stop offset="100%" stop-color="#0c0e13"></stop>
          </linearGradient>
          <linearGradient id="rod" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#7d869c"></stop>
            <stop offset="50%" stop-color="#cfd6e6"></stop>
            <stop offset="100%" stop-color="#6a7488"></stop>
          </linearGradient>
          <linearGradient id="bob" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#aeb6c8"></stop>
            <stop offset="100%" stop-color="#5b647a"></stop>
          </linearGradient>
          <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="2.5" result="b"></feGaussianBlur>
            <feMerge>
              <feMergeNode in="b"></feMergeNode>
              <feMergeNode in="SourceGraphic"></feMergeNode>
            </feMerge>
          </filter>

          <!-- dark rosewood: deep red-brown, sheen rounded across the width -->
          <linearGradient id="woodgrad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#260b07"></stop>
            <stop offset="42%" stop-color="#4d1810"></stop>
            <stop offset="58%" stop-color="#3d130c"></stop>
            <stop offset="100%" stop-color="#160604"></stop>
          </linearGradient>
          <!-- elongated turbulence streaks = vertical wood grain, clipped to
               whatever shape uses the filter and laid over the base wood.
               Computed in user space, so the grain lines up across the cap,
               frame and base as if cut from one plank. -->
          <filter id="woodgrain" x="-5%" y="-5%" width="110%" height="110%">
            <feTurbulence
              type="fractalNoise"
              baseFrequency="0.07 0.009"
              numOctaves="4"
              seed="11"
              result="noise"></feTurbulence>
            <feColorMatrix
              in="noise"
              type="matrix"
              values="0 0 0 0 0.14
                      0 0 0 0 0.08
                      0 0 0 0 0.03
                      0 0 0 0.5 0"
              result="grain"></feColorMatrix>
            <feComposite
              in="grain"
              in2="SourceGraphic"
              operator="in"
              result="grainIn"></feComposite>
            <feMerge>
              <feMergeNode in="SourceGraphic"></feMergeNode>
              <feMergeNode in="grainIn"></feMergeNode>
            </feMerge>
          </filter>
        </defs>

        <!-- body -->
        <polygon
          points={bodyPts}
          fill="url(#body)"
          stroke="#000"
          stroke-width="1"></polygon>
        <!-- little pyramid cap, in wood -->
        <polygon
          points={capPts}
          fill="url(#woodgrad)"
          filter="url(#woodgrain)"
          stroke="#241407"
          stroke-width="1"
          stroke-linejoin="round"></polygon>

        <!-- double-edged wood frame around the scale -->
        <path
          d={framePath}
          fill-rule="evenodd"
          fill="url(#woodgrad)"
          filter="url(#woodgrain)"
          stroke="#241407"
          stroke-width="1.5"
          stroke-linejoin="round"></path>
        <!-- inner bevel highlight = the second (inner) edge of each side rail;
             two separate lines, so no edge crosses the top or bottom -->
        <polyline
          points={bevelLeftPts}
          fill="none"
          stroke="#caa06a"
          stroke-width="0.8"
          opacity="0.5"></polyline>
        <polyline
          points={bevelRightPts}
          fill="none"
          stroke="#caa06a"
          stroke-width="0.8"
          opacity="0.5"></polyline>

        <!-- central channel: black with square white borders -->
        <rect
          x="123"
          y="48"
          width="54"
          height="295"
          fill="#000"
          stroke="#ffffff"
          stroke-width="1"></rect>

        <!-- tempo numbers, alternating left/right of the slot -->
        <g class="ticks">
          {
            marks.map((m) => {
              const y = yForBpm(m.bpm);
              return m.side === -1 ? (
                <g>
                  <line
                    x1={109}
                    y1={y}
                    x2={123}
                    y2={y}
                    stroke="#ffffff"
                    stroke-width="1"
                  />
                  <text
                    class="num"
                    x={106}
                    y={y}
                    text-anchor="end"
                    dominant-baseline="central"
                  >
                    {m.bpm}
                  </text>
                </g>
              ) : (
                <g>
                  <line
                    x1={177}
                    y1={y}
                    x2={191}
                    y2={y}
                    stroke="#ffffff"
                    stroke-width="1"
                  />
                  <text
                    class="num"
                    x={194}
                    y={y}
                    text-anchor="start"
                    dominant-baseline="central"
                  >
                    {m.bpm}
                  </text>
                </g>
              );
            })
          }
        </g>

        <!-- italian tempo names down the black center -->
        <g class="zone-labels">
          {
            zones.map((z) => (
              <text
                x={150}
                y={yForBpm(z.bpm)}
                text-anchor="middle"
                dominant-baseline="central"
              >
                {z.name}
              </text>
            ))
          }
        </g>
      </svg>

      <!-- pendulum layer: animated, no filters -->
      <svg class="dev-layer" viewBox="0 0 300 480" aria-hidden="true">
        <!-- pendulum: rod + weight, rotates around the (hidden) pivot -->
        <g id="rodgroup">
          <!-- invisible wide hit area so the thin rod is easy to grab (esp. on
               touch). First child + pointer-events:all; the weight is painted
               after this, so it still wins touches over itself. -->
          <rect
            id="rod-hit"
            x="128"
            y="40"
            width="44"
            height="392"
            fill="none"
            pointer-events="all"></rect>
          <rect
            x="147.5"
            y="40"
            width="5"
            height="392"
            rx="2.5"
            fill="url(#rod)"></rect>
          <circle
            cx="150"
            cy="38"
            r="9"
            fill="url(#rod)"
            stroke="#2b3040"
            stroke-width="0.5"></circle>
          <g id="weight" transform={`translate(${PIVOT_X} ${yForBpm(120)})`}>
            <polygon
              points="-22,-13 22,-13 17,13 -17,13"
              fill="url(#bob)"
              stroke="#3a4050"
              stroke-width="1"></polygon>
            <rect
              x="-3"
              y="-13"
              width="6"
              height="26"
              fill="#05060a"
              opacity="0.55"></rect>
          </g>
        </g>
      </svg>

      <!-- panel layer ON TOP, hiding the pivot + lower rod, in wood -->
      <svg class="dev-layer" viewBox="0 0 300 480" aria-hidden="true">
        <polygon
          points={panelPts}
          fill="url(#woodgrad)"
          filter="url(#woodgrain)"
          stroke="#241407"
          stroke-width="1.5"
          stroke-linejoin="round"></polygon>
      </svg>

      <!-- BPM + controls live in the metronome's bottom panel -->
      <div class="panel-ui">
        <div class="readout">
          <span class="bpm-line">
            <span class="bpm" id="bpm">120</span>
            <span class="bpm-unit">BPM</span>
          </span>

          <span class="zone" id="zone">Allegro</span>
        </div>
        <div class="controls">
          <button id="toggle" class="knob-btn" type="button" aria-label="Start">
            <svg class="icon-play" viewBox="0 0 24 24" aria-hidden="true">
              <polygon points="8,5 19,12 8,19"></polygon>
            </svg>
            <svg class="icon-pause" viewBox="0 0 24 24" aria-hidden="true">
              <rect x="7" y="5" width="3.5" height="14" rx="1"></rect>
              <rect x="13.5" y="5" width="3.5" height="14" rx="1"></rect>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</ToyLayout>

<!-- Lock the page so dragging the weight can't scroll/bounce the page on
     mobile. Scoped to this page (toy pages are standalone documents). -->
<style is:global>
  html,
  body {
    height: 100%;
    overflow: hidden;
    overscroll-behavior: none;
    touch-action: none;
  }
</style>

<style>
  .metronome {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .device {
    /* Sized by the available height, capped at the container width, so it fills
       the page vertically on wide screens and never distorts (aspect-ratio +
       a single definite dimension). */
    width: min(100%, calc((100vh - 5.5rem) * 300 / 480));
    aspect-ratio: 300 / 480;
    container-type: size;
    position: relative;
    touch-action: none;
    user-select: none;
    -webkit-user-select: none;
    outline: none;
    filter: drop-shadow(0 16px 32px rgba(0, 0, 0, 0.6));
  }
  .device:focus-visible {
    filter: drop-shadow(0 0 0 2px var(--accent))
      drop-shadow(0 16px 32px rgba(0, 0, 0, 0.6));
  }
  /* The three layers stack in document order (base, pendulum, panel). They
     don't capture pointer events (so a tap falls through to the device, which
     delegates); only the pendulum re-enables them below. */
  .device .dev-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
  }
  /* Grab cursor only over the interactive pendulum (rod + weight). */
  #rodgroup {
    cursor: grab;
    pointer-events: auto;
  }
  .device:active #rodgroup {
    cursor: grabbing;
  }
  /* Rotate about the hidden pivot via a GPU-composited CSS transform (no
     per-frame repaint, no filter recompute — the pendulum is on its own
     filter-free layer). */
  #rodgroup {
    transform-box: view-box;
    transform-origin: 150px 430px;
    will-change: transform;
  }
  .ticks .num {
    font-family: 'Space Mono', monospace;
    font-size: 6.5px;
    fill: #ffffff;
  }
  .zone-labels text {
    font-family: 'Space Mono', monospace;
    font-size: 6.5px;
    font-style: italic;
    fill: #aab2c6;
    letter-spacing: 0.02em;
  }

  /* The BPM + controls sit over the base panel of the device. Sizes use
     container units (cqw = 1% of device width) so they scale with the
     metronome at any height. */
  .panel-ui {
    position: absolute;
    left: 50%;
    /* center of the wood base panel (≈ (345+440)/2 of the 480 viewBox) */
    top: 82%;
    transform: translate(-50%, -50%);
    width: 62%;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 9cqw;
  }
  /* Recessed black display window cut into the wood base. "120 BPM" on one
     row, the tempo name below it; sized to hug its contents. */
  .readout {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2cqw;
    /* fixed width so the panel doesn't grow at 3-digit BPMs or long tempo
       names (widest content is "Prestissimo") */
    width: 31cqw;
    box-sizing: border-box;
    padding: 1.4cqw 3cqw;
    border-radius: 1.4cqw;
    background: linear-gradient(180deg, #000 0%, #0c0c0c 100%);
    border: 1px solid #000;
    box-shadow:
      inset 0 0.9cqw 1.2cqw rgba(0, 0, 0, 0.9),
      inset 0 -0.4cqw 0.5cqw rgba(255, 255, 255, 0.04),
      0 0.4cqw 0.5cqw rgba(255, 230, 210, 0.07);
  }
  .bpm {
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 9cqw;
    color: #fff;
    line-height: 1;
    font-variant-numeric: tabular-nums;
    text-shadow: 0 0 1.5cqw rgba(0, 0, 0, 0.6);
    /* reserve room for 3 digits and right-align, so "BPM" never shifts —
       a 2-digit value just leaves blank space on the left */
    display: inline-block;
    width: 17.5cqw;
    text-align: right;
    white-space: nowrap;
  }
  .bpm-line {
    display: flex;
    align-items: baseline;
    white-space: nowrap;
    gap: 1.6cqw;
  }
  .bpm-unit {
    font-size: 3.4cqw;
    color: #fff;
    letter-spacing: 0.06em;
  }
  .zone {
    font-style: italic;
    color: #fff;
    font-size: 3.4cqw;
  }

  .controls {
    display: none;
    align-items: center;
    gap: 4cqw;
  }
  /* Skeuomorphic play/pause button — a raised ebony cap with a soft
     inset highlight. */
  .knob-btn {
    display: grid;
    place-items: center;
    width: 17cqw;
    height: 17cqw;
    padding: 0;
    border-radius: 50%;
    cursor: pointer;
    border: 1px solid #050403;
    background: linear-gradient(160deg, #2b2622 0%, #14110e 48%, #0a0806 100%);
    box-shadow:
      inset 0 0.6cqw 0.6cqw rgba(255, 248, 240, 0.14),
      inset 0 -0.8cqw 1cqw rgba(0, 0, 0, 0.7),
      0 1.4cqw 2.4cqw rgba(0, 0, 0, 0.55);
    transition:
      box-shadow 0.08s ease,
      transform 0.08s ease;
  }
  .knob-btn:active {
    transform: translateY(0.4cqw);
    background: linear-gradient(160deg, #1c1916 0%, #100d0b 48%, #070605 100%);
    box-shadow:
      inset 0 0.6cqw 0.8cqw rgba(0, 0, 0, 0.6),
      inset 0 -0.4cqw 0.6cqw rgba(255, 248, 240, 0.07),
      0 0.5cqw 1cqw rgba(0, 0, 0, 0.5);
  }
  .knob-btn svg {
    width: 8.5cqw;
    height: 8.5cqw;
    fill: #f0e6df;
    filter: drop-shadow(0 0.3cqw 0.3cqw rgba(0, 0, 0, 0.6));
  }
  /* show the icon matching the next action: play when stopped, pause when running */
  .knob-btn .icon-pause {
    display: none;
  }
  .knob-btn.running .icon-play {
    display: none;
  }
  .knob-btn.running .icon-pause {
    display: block;
  }
  /* Vibrate toggle lives in the ToyLayout header (no container context there,
     so use fixed rem sizing rather than container units). */
  .vib {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: rgb(var(--gray));
    cursor: pointer;
    user-select: none;
  }
  .vib input {
    accent-color: var(--accent);
    width: 1rem;
    height: 1rem;
    cursor: pointer;
  }
  .header-wrap {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .instruction {
    font-style: italic;
    font-size: 0.7rem;
  }
</style>

<script>
  function initMetronome() {
    const root = document.getElementById('metronome');
    if (!root || root.dataset.ready === '1') return;
    root.dataset.ready = '1';

    const device = document.getElementById('device')!;
    const rodgroup = document.getElementById('rodgroup')!;
    const weight = document.getElementById('weight')!;
    const bpmEl = document.getElementById('bpm')!;
    const zoneEl = document.getElementById('zone')!;
    const toggleBtn = document.getElementById('toggle') as HTMLButtonElement;
    const vibChk = document.getElementById('vib') as HTMLInputElement;

    const PIVOT_X = 150;
    const PIVOT_Y = 430;
    const SCALE_TOP_Y = 60;
    const SCALE_BOT_Y = 335;
    const BPM_MIN = 40;
    const BPM_MAX = 208;
    const MAX_ANGLE = 6; // degrees of swing each side

    const yForBpm = (bpm: number) =>
      SCALE_TOP_Y +
      ((bpm - BPM_MIN) / (BPM_MAX - BPM_MIN)) * (SCALE_BOT_Y - SCALE_TOP_Y);
    const bpmForY = (y: number) => {
      const clamped = Math.max(SCALE_TOP_Y, Math.min(SCALE_BOT_Y, y));
      const f = (clamped - SCALE_TOP_Y) / (SCALE_BOT_Y - SCALE_TOP_Y);
      return Math.round(BPM_MIN + f * (BPM_MAX - BPM_MIN));
    };

    function zoneFor(bpm: number) {
      if (bpm < 60) return 'Largo';
      if (bpm < 66) return 'Larghetto';
      if (bpm < 76) return 'Adagio';
      if (bpm < 108) return 'Andante';
      if (bpm < 120) return 'Moderato';
      if (bpm < 168) return 'Allegro';
      if (bpm < 200) return 'Presto';
      return 'Prestissimo';
    }

    let bpm = 120;
    let running = false;
    // The pendulum runs on the wall clock (performance.now), so it swings even
    // before the AudioContext has resumed — on mobile the audio clock starts
    // frozen, which used to freeze the animation. swingStartMs is the time of
    // visual phase 0 (a swing extreme); beats fall on integer phases.
    let swingStartMs = 0;
    let lastBeatIndex = -1; // highest beat index already scheduled for audio
    let rafId = 0;
    let schedulerId = 0;
    const LOOKAHEAD = 0.1; // schedule beats up to 100ms ahead (s)
    const SCHED_INTERVAL = 25; // scheduler pass cadence (ms)

    // ---- audio ----
    let audioCtx: AudioContext | null = null;
    let clickBuffer: AudioBuffer | null = null;
    function ensureAudio() {
      if (!audioCtx) {
        const Ctx = window.AudioContext || (window as any).webkitAudioContext;
        if (Ctx) {
          audioCtx = new Ctx();
          clickBuffer = makeNoiseBuffer(audioCtx, 0.02);
        }
      }
      if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
      return audioCtx;
    }

    // one fixed noise burst, reused for every tick so the transient is identical
    function makeNoiseBuffer(ctx: AudioContext, dur: number) {
      const buf = ctx.createBuffer(1, ctx.sampleRate * dur, ctx.sampleRate);
      const d = buf.getChannelData(0);
      for (let i = 0; i < d.length; i++) {
        const k = 1 - i / d.length;
        d[i] = (Math.random() * 2 - 1) * k * k;
      }
      return buf;
    }

    // a short woody "tok", scheduled at a precise audio-clock time
    function playTick(when: number) {
      const ctx = audioCtx;
      if (!ctx) return;
      const osc = ctx.createOscillator();
      const g = ctx.createGain();
      osc.type = 'triangle';
      osc.frequency.setValueAtTime(820, when);
      osc.frequency.exponentialRampToValueAtTime(280, when + 0.04);
      g.gain.setValueAtTime(0.0001, when);
      g.gain.exponentialRampToValueAtTime(0.6, when + 0.002);
      g.gain.exponentialRampToValueAtTime(0.0001, when + 0.08);
      osc.connect(g).connect(ctx.destination);
      osc.start(when);
      osc.stop(when + 0.09);
      if (clickBuffer) {
        const src = ctx.createBufferSource();
        src.buffer = clickBuffer;
        const bp = ctx.createBiquadFilter();
        bp.type = 'bandpass';
        bp.frequency.value = 2600;
        const ng = ctx.createGain();
        ng.gain.value = 0.35;
        src.connect(bp).connect(ng).connect(ctx.destination);
        src.start(when);
      }
    }

    function vibrate(ms: number) {
      if (vibChk.checked && 'vibrate' in navigator) {
        try {
          navigator.vibrate(ms);
        } catch {
          /* best effort */
        }
      }
    }

    // short click for when the weight hits a travel limit
    function playClick() {
      const ctx = ensureAudio();
      if (!ctx) return;
      const now = ctx.currentTime;
      const dur = 0.025;
      const buf = ctx.createBuffer(1, ctx.sampleRate * dur, ctx.sampleRate);
      const d = buf.getChannelData(0);
      for (let i = 0; i < d.length; i++) {
        const k = 1 - i / d.length;
        d[i] = (Math.random() * 2 - 1) * k * k;
      }
      const src = ctx.createBufferSource();
      src.buffer = buf;
      const bp = ctx.createBiquadFilter();
      bp.type = 'bandpass';
      bp.frequency.value = 1800;
      bp.Q.value = 0.7;
      const g = ctx.createGain();
      g.gain.value = 0.4;
      src.connect(bp).connect(g).connect(ctx.destination);
      src.start(now);
    }

    // ---- rendering ----
    let currentAngle = 0; // last rod angle drawn, in degrees
    function setRodAngle(deg: number) {
      currentAngle = deg;
      // CSS transform (origin set in CSS to the pivot) so the browser can
      // composite the rotation on the GPU instead of repainting the SVG.
      rodgroup.style.transform = `rotate(${deg}deg)`;
    }
    function renderWeight() {
      weight.setAttribute('transform', `translate(${PIVOT_X} ${yForBpm(bpm)})`);
    }
    function renderReadout() {
      bpmEl.textContent = String(bpm);
      zoneEl.textContent = zoneFor(bpm);
      device.setAttribute('aria-valuenow', String(bpm));
    }
    function renderAll() {
      renderWeight();
      renderReadout();
    }

    // ---- run loop ----
    // A lookahead scheduler drives the beat on the precise audio clock, while
    // requestAnimationFrame only animates the pendulum. Decoupling them keeps
    // both the timing and the tick's timbre rock-steady regardless of frame
    // rate or main-thread jitter. (Pattern: "A Tale of Two Clocks".)
    function scheduler() {
      const ctx = audioCtx;
      // Only schedule once the context is actually running; until then the
      // pendulum still swings on the wall clock and beats are simply skipped.
      if (!ctx || ctx.state !== 'running') return;
      const beatMs = (60 / bpm) * 1000;
      const nowMs = performance.now();
      // first unscheduled beat at or after now
      let k = Math.max(
        lastBeatIndex + 1,
        Math.ceil((nowMs - swingStartMs) / beatMs - 1e-6),
      );
      for (;;) {
        const beatWallMs = swingStartMs + k * beatMs;
        const leadMs = beatWallMs - nowMs;
        if (leadMs / 1000 >= LOOKAHEAD) break;
        // map the beat's wall time onto the audio clock for sample-accurate play
        playTick(ctx.currentTime + Math.max(0, leadMs) / 1000);
        setTimeout(
          () => vibrate(15),
          Math.max(0, beatWallMs - performance.now()),
        );
        lastBeatIndex = k;
        k++;
      }
    }

    function animate(nowMs: number) {
      const beatSec = 60 / bpm;
      const phase = (nowMs - swingStartMs) / 1000 / beatSec;
      setRodAngle(MAX_ANGLE * Math.cos(Math.PI * phase));
      rafId = requestAnimationFrame(animate);
    }

    // Start swinging. `fromDeg` is the angle to begin from (the rod's current
    // position when released by a drag); default is the right extreme, used by
    // the spacebar/button. Phase is chosen so the swing continues smoothly from
    // that angle, heading back toward center — no jump to the other side.
    function start(fromDeg = MAX_ANGLE) {
      ensureAudio(); // create + resume; may finish asynchronously on mobile
      running = true;
      const beatSec = 60 / bpm;
      const clamped = Math.max(-MAX_ANGLE, Math.min(MAX_ANGLE, fromDeg));
      // angle = MAX·cos(π·phase); solve for the phase at this angle, on the
      // returning side for a left-of-center release.
      let phase = Math.acos(clamped / MAX_ANGLE) / Math.PI; // 0..1
      if (clamped < 0) phase = 2 - phase; // 1..1.5 → moving back toward center
      swingStartMs = performance.now() - phase * beatSec * 1000;
      // the next beat to schedule is the next swing extreme (integer phase)
      lastBeatIndex = Math.ceil(phase - 1e-6) - 1;
      toggleBtn.classList.add('running');
      toggleBtn.setAttribute('aria-label', 'Pause');
      clearInterval(schedulerId);
      schedulerId = window.setInterval(scheduler, SCHED_INTERVAL);
      scheduler();
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(animate);
    }
    function stop() {
      running = false;
      clearInterval(schedulerId);
      schedulerId = 0;
      cancelAnimationFrame(rafId);
      glideToCenter();
      toggleBtn.classList.remove('running');
      toggleBtn.setAttribute('aria-label', 'Start');
    }

    // Ease the rod from its current angle back to upright after stopping.
    function glideToCenter() {
      const from = currentAngle;
      if (Math.abs(from) < 0.05) {
        setRodAngle(0);
        return;
      }
      const dur = 450;
      const t0 = performance.now();
      cancelAnimationFrame(rafId);
      const step = (now: number) => {
        const k = Math.min(1, (now - t0) / dur);
        const e = 1 - Math.pow(1 - k, 3); // easeOutCubic
        setRodAngle(from * (1 - e));
        if (k < 1) rafId = requestAnimationFrame(step);
      };
      rafId = requestAnimationFrame(step);
    }

    // Adjust tempo live. While running, re-time the beat to the new tempo but
    // PRESERVE the current phase, so the pendulum keeps swinging smoothly and
    // the change itself never triggers an extra click.
    function setBpm(next: number) {
      const clamped = Math.max(BPM_MIN, Math.min(BPM_MAX, next));
      if (clamped === bpm) return;
      const prevBpm = bpm;
      bpm = clamped;
      renderAll();
      // tactile click when the weight first reaches either travel limit (fires
      // once — repeats are short-circuited by the clamped === bpm guard above)
      if (clamped === BPM_MIN || clamped === BPM_MAX) {
        playClick();
        vibrate(20);
      }
      if (running) {
        const nowMs = performance.now();
        const oldBeatMs = (60 / prevBpm) * 1000;
        const newBeatMs = (60 / bpm) * 1000;
        // keep the same fractional phase so the pendulum doesn't jump
        const frac = ((((nowMs - swingStartMs) / oldBeatMs) % 1) + 1) % 1;
        swingStartMs = nowMs - frac * newBeatMs;
        // next beat to schedule is the upcoming extreme at the new tempo
        lastBeatIndex =
          Math.ceil((nowMs - swingStartMs) / newBeatMs - 1e-6) - 1;
      }
    }

    // Pointer Y -> bpm via the fixed scale (for dragging the weight).
    function pointerToBpm(clientY: number) {
      const rect = device.getBoundingClientRect();
      const svgY = ((clientY - rect.top) / rect.height) * 480;
      return bpmForY(svgY);
    }
    // Pointer position -> rod angle about the (hidden) pivot, clamped to the
    // swing range (for dragging the rod to push it into motion).
    function pointerToAngle(clientX: number, clientY: number) {
      const rect = device.getBoundingClientRect();
      const svgX = ((clientX - rect.left) / rect.width) * 300;
      const svgY = ((clientY - rect.top) / rect.height) * 480;
      const deg = (Math.atan2(svgX - PIVOT_X, PIVOT_Y - svgY) * 180) / Math.PI;
      return Math.max(-MAX_ANGLE, Math.min(MAX_ANGLE, deg));
    }

    // Two distinct gestures: drag the WEIGHT to set tempo, or drag the ROD to
    // swing it and let go to start the motion.
    let mode: 'none' | 'tempo' | 'swing' = 'none';
    device.addEventListener('pointerdown', (e) => {
      const t = e.target as Element;
      if (t.closest('.panel-ui')) return; // panel controls handle themselves
      // Dragging the weight always adjusts tempo, running or not.
      if (weight.contains(t)) {
        mode = 'tempo';
        device.setPointerCapture(e.pointerId);
        setBpm(pointerToBpm(e.clientY));
        return;
      }
      // While running, touching the rod or body stops it (like catching the
      // pendulum).
      if (running) {
        stop();
        return;
      }
      // Stopped: grab the rod to push it; release starts the swing.
      if (rodgroup.contains(t)) {
        mode = 'swing';
        device.setPointerCapture(e.pointerId);
        cancelAnimationFrame(rafId);
        setRodAngle(pointerToAngle(e.clientX, e.clientY));
      }
    });
    device.addEventListener('pointermove', (e) => {
      if (mode === 'tempo') setBpm(pointerToBpm(e.clientY));
      else if (mode === 'swing')
        setRodAngle(pointerToAngle(e.clientX, e.clientY));
    });
    function endDrag(e: PointerEvent) {
      if (mode === 'none') return;
      const wasSwing = mode === 'swing';
      mode = 'none';
      try {
        device.releasePointerCapture(e.pointerId);
      } catch {
        /* ignore */
      }
      // letting go of the rod sets it going from where it was released
      if (wasSwing) start(currentAngle);
    }
    device.addEventListener('pointerup', endDrag);
    device.addEventListener('pointercancel', endDrag);

    device.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowUp' || e.key === 'ArrowRight') {
        setBpm(bpm + 1); // up = faster on the readout, regardless of weight dir
        e.preventDefault();
      } else if (e.key === 'ArrowDown' || e.key === 'ArrowLeft') {
        setBpm(bpm - 1);
        e.preventDefault();
      }
    });

    // Spacebar plays/pauses from anywhere on the page (the play button is
    // hidden), unless focus is on a form control like the Vibrate checkbox.
    function onSpace(e: KeyboardEvent) {
      if (e.code !== 'Space' && e.key !== ' ') return;
      const t = e.target as HTMLElement | null;
      if (
        t &&
        (t.tagName === 'INPUT' || t.tagName === 'BUTTON' || t.isContentEditable)
      ) {
        return;
      }
      e.preventDefault();
      running ? stop() : start();
    }
    window.addEventListener('keydown', onSpace);

    toggleBtn.addEventListener('click', () => (running ? stop() : start()));

    // ---- cleanup on navigation ----
    function cleanup() {
      cancelAnimationFrame(rafId);
      clearInterval(schedulerId);
      window.removeEventListener('keydown', onSpace);
      if ('vibrate' in navigator) {
        try {
          navigator.vibrate(0);
        } catch {
          /* ignore */
        }
      }
      if (audioCtx) {
        audioCtx.close().catch(() => {});
        audioCtx = null;
      }
      root!.dataset.ready = '';
    }
    document.addEventListener('astro:before-swap', cleanup, { once: true });
    window.addEventListener('pagehide', cleanup, { once: true });

    renderAll();
    setRodAngle(0);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMetronome);
  } else {
    initMetronome();
  }
  document.addEventListener('astro:page-load', initMetronome);
</script>
