---
import { getCollection } from 'astro:content';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../lib/auth';

export const prerender = false;

const loggedIn = isAuthenticated(Astro.request.headers.get('cookie'));
const error = Astro.url.searchParams.get('error');
const notice = Astro.url.searchParams.get('notice');

let posts: { slug: string; title: string; pubDate: Date }[] = [];
if (loggedIn) {
  const all = await getCollection('blog');
  posts = all
    .map((p) => ({ slug: p.id, title: p.data.title, pubDate: p.data.pubDate }))
    .sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());
}
---

<AdminLayout title="admin">
  {
    !loggedIn ? (
      <div class="login-page">
        <h1>ADMIN LOGIN</h1>
        <div class="login-center">
          <form method="POST" action="/admin/api/login">
            {error && <div class="msg error">{error}</div>}
            <input
              id="password"
              name="password"
              type="password"
              autofocus
              required
            />
            <button type="submit" class="enter-btn">
              Enter
            </button>
          </form>
        </div>
      </div>
    ) : (
      <>
        {notice && <div class="msg ok">{notice}</div>}
        <div class="row" style="justify-content: space-between;">
          <h1>admin</h1>
          <form method="POST" action="/admin/api/logout">
            <button type="submit">Log out</button>
          </form>
        </div>

        <div class="row">
          <a href="/admin/new">+ New post</a>
          <a href="/admin/library/new">+ Add library link</a>
        </div>

        <h2>Posts</h2>
        <ul class="posts">
          {posts.map((p) => (
            <li>
              <span style="color:#888; min-width:6rem;">
                {p.pubDate.toISOString().slice(0, 10)}
              </span>
              <a href={`/admin/edit/${p.slug}`} style="flex:1;">
                {p.title}
              </a>
              <form
                method="POST"
                action={`/admin/api/posts/${p.slug}/delete`}
                onsubmit="return confirm('Delete this post?');"
              >
                <button type="submit" style="border-color:#743;">
                  Delete
                </button>
              </form>
            </li>
          ))}
        </ul>
      </>
    )
  }
</AdminLayout>

<style>
  .login-page {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    padding: 2rem 0;
    box-sizing: border-box;
  }

  .login-page h1 {
    margin: 0;
    text-align: center;
  }

  .login-center {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0em 1em;
  }

  .login-center form {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    width: 100%;
    max-width: 320px;
    padding-bottom: 18em;
  }

  input {
    width: 100%;
  }

  .msg.error {
    color: red;
  }

  .enter-btn {
    font: inherit;
    font-size: 0.85rem;
    color: #2337ff;
    background: transparent;
    border: 1px solid #2337ff;
    width: 100%;
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .enter-btn:hover {
    background-color: #2337ff;
    color: #000;
  }

  @media (max-width: 480px) {
    .login-center form {
      max-width: 100%;
    }
  }
</style>
