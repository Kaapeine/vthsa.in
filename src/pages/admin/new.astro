---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../lib/auth';
import { todayIso } from '../../lib/content';

export const prerender = false;

if (!isAuthenticated(Astro.request.headers.get('cookie'))) {
  return Astro.redirect('/admin');
}
const error = Astro.url.searchParams.get('error');
---

<AdminLayout title="new post">
  <div class="new-post-page">
    <a href="/admin" class="back">&larr; back</a>
    <h1>New post</h1>
    {error && <div class="msg error">{error}</div>}
    <form method="POST" action="/admin/api/posts">
      <input type="hidden" name="mode" value="create" />
      <div class="field">
        <label for="title">Title</label>
        <input id="title" name="title" required />
      </div>
      <div class="field">
        <label for="description">Description <span class="optional">(optional)</span></label>
        <input id="description" name="description" />
      </div>
      <div class="field">
        <label for="tags">Tags (comma-separated)</label>
        <input id="tags" name="tags" />
      </div>
      <div class="field">
        <label for="pubDate">Publish date</label>
        <input id="pubDate" name="pubDate" type="date" value={todayIso()} required />
      </div>
      <div class="field field-checkbox">
        <label>
          <input type="checkbox" name="draft" value="true" />
          Draft (hidden from public)
        </label>
      </div>
      <div class="field field-body">
        <label for="body">Body</label>
        <textarea id="body" name="body" required></textarea>
      </div>
      <button type="submit" class="save-btn">Publish</button>
    </form>
  </div>
</AdminLayout>

<style>
  .new-post-page {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem 0 3rem;
  }

  .back {
    font-size: 0.85rem;
    color: #6cf;
    text-decoration: none;
  }

  .back:hover {
    text-decoration: underline;
  }

  h1 {
    font-size: 1.2rem;
    margin: 0;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  label {
    font-size: 0.78rem;
    color: #888;
    letter-spacing: 0.04em;
  }

  input {
    width: 100%;
    box-sizing: border-box;
    background: #1b1b1b;
    color: #eee;
    border: 1px solid #444;
    border-radius: 4px;
    padding: 0.5rem;
    font: inherit;
    font-size: 0.9rem;
  }

  input:focus, textarea:focus {
    outline: none;
    border-color: #2337ff;
  }

  textarea {
    width: 100%;
    box-sizing: border-box;
    background: #1b1b1b;
    color: #eee;
    border: 1px solid #444;
    border-radius: 4px;
    padding: 0.5rem;
    font: inherit;
    font-size: 0.9rem;
    line-height: 1.6;
    resize: vertical;
    min-height: 60vh;
    field-sizing: content;
  }

  .save-btn {
    font: inherit;
    font-size: 0.85rem;
    color: #2337ff;
    background: transparent;
    border: 1px solid #2337ff;
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
    align-self: flex-start;
  }

  .save-btn:hover {
    background-color: #2337ff;
    color: #000;
  }

  .optional {
    color: #555;
    font-weight: normal;
  }

  .field-checkbox {
    flex-direction: row;
    align-items: center;
  }

  .field-checkbox label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: #bbb;
    cursor: pointer;
  }

  .field-checkbox input[type="checkbox"] {
    width: auto;
    accent-color: #2337ff;
  }

  @media (max-width: 480px) {
    .save-btn {
      align-self: stretch;
    }
  }
</style>
