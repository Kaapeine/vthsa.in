---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../../lib/auth';
import { categories } from '../../../lib/categories';

export const prerender = false;

if (!isAuthenticated(Astro.request.headers.get('cookie'))) {
  return Astro.redirect('/admin');
}
const error = Astro.url.searchParams.get('error');
const FALLBACK = { lat: 12.9716, lng: 77.5946 };
---

<AdminLayout title="new tag">
  <div class="new-tag-page">
    <a href="/admin/map" class="back">&larr; back</a>
    <h1>New map tag</h1>
    {error && <div class="msg error">{error}</div>}

    <p class="hint">Tap the map or drag the pin to set the exact spot.</p>
    <div id="pick-map"></div>

    <form method="POST" action="/admin/api/map" enctype="multipart/form-data">
      <input type="hidden" name="mode" value="create" />
      <input type="hidden" id="lat" name="lat" value={FALLBACK.lat} />
      <input type="hidden" id="lng" name="lng" value={FALLBACK.lng} />

      <div class="field">
        <label for="title">Title</label>
        <input id="title" name="title" required />
      </div>

      <div class="field">
        <label for="category">Category</label>
        <select id="category" name="category" required>
          {categories.map((c) => <option value={c.id}>{c.emoji} {c.label}</option>)}
        </select>
      </div>

      <div class="field">
        <label for="image">Photo <span class="optional">(optional)</span></label>
        <input id="image" name="image" type="file" accept="image/*" capture="environment" />
      </div>

      <div class="field">
        <label for="notes">Notes <span class="optional">(optional)</span></label>
        <textarea id="notes" name="notes"></textarea>
      </div>

      <button type="submit" class="save-btn">Save tag</button>
    </form>
  </div>

  <script is:inline define:vars={{ fallback: FALLBACK }}>
    (function () {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      s.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
      s.crossOrigin = '';
      s.onload = function () {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
        link.integrity = 'sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=';
        link.crossOrigin = '';
        document.head.appendChild(link);

        delete L.Icon.Default.prototype._getIconUrl;
        L.Icon.Default.mergeOptions({
          iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
          iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
          shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
        });

        const latInput = document.getElementById('lat');
        const lngInput = document.getElementById('lng');

        const map = L.map('pick-map').setView([fallback.lat, fallback.lng], 13);
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 19,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
          referrerPolicy: 'origin',
        }).addTo(map);

        const marker = L.marker([fallback.lat, fallback.lng], { draggable: true }).addTo(map);

        function sync(latlng) {
          latInput.value = latlng.lat.toFixed(6);
          lngInput.value = latlng.lng.toFixed(6);
        }
        sync(marker.getLatLng());
        marker.on('dragend', () => sync(marker.getLatLng()));
        map.on('click', (e) => { marker.setLatLng(e.latlng); sync(e.latlng); });

        if (navigator.geolocation) {
          navigator.geolocation.getCurrentPosition(
            (pos) => {
              const here = L.latLng(pos.coords.latitude, pos.coords.longitude);
              map.setView(here, 16);
              marker.setLatLng(here);
              sync(here);
            },
            () => { /* denied — keep fallback */ },
            { enableHighAccuracy: true, timeout: 10000 },
          );
        }
      };
      document.head.appendChild(s);
    })();
  </script>
</AdminLayout>

<style>
  .new-tag-page {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem 0 3rem;
  }

  .back {
    font-size: 0.85rem;
    color: #6cf;
    text-decoration: none;
  }

  .back:hover {
    text-decoration: underline;
  }

  h1 {
    font-size: 1.2rem;
    margin: 0;
  }

  .hint {
    font-size: 0.78rem;
    color: #888;
    margin: 0;
  }

  #pick-map {
    height: 45vh;
    border-radius: 4px;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  label {
    font-size: 0.78rem;
    color: #888;
    letter-spacing: 0.04em;
  }

  input,
  select,
  textarea {
    width: 100%;
    box-sizing: border-box;
    background: #1b1b1b;
    color: #eee;
    border: 1px solid #444;
    border-radius: 4px;
    padding: 0.5rem;
    font: inherit;
    font-size: 0.9rem;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: #2337ff;
  }

  textarea {
    line-height: 1.6;
    resize: vertical;
    min-height: 8rem;
    field-sizing: content;
  }

  .optional {
    color: #555;
    font-weight: normal;
  }

  .save-btn {
    font: inherit;
    font-size: 0.85rem;
    color: #2337ff;
    background: transparent;
    border: 1px solid #2337ff;
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    cursor: pointer;
    align-self: flex-start;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .save-btn:hover {
    background-color: #2337ff;
    color: #000;
  }

  @media (max-width: 480px) {
    .save-btn {
      align-self: stretch;
    }
  }
</style>
