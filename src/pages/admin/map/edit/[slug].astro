---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../../../lib/auth';
import { getFile } from '../../../../lib/github';
import { isValidSlug } from '../../../../lib/content';
import { parseTagFile, tagImageUrl, tagPath } from '../../../../lib/map';
import { categories } from '../../../../lib/categories';

export const prerender = false;

if (!isAuthenticated(Astro.request.headers.get('cookie'))) {
  return Astro.redirect('/admin');
}

const { slug } = Astro.params;
if (!slug || !isValidSlug(slug)) {
  return Astro.redirect('/admin?error=' + encodeURIComponent('Invalid tag slug'));
}
const error = Astro.url.searchParams.get('error');

const file = await getFile(tagPath(slug));
if (!file) {
  return Astro.redirect('/admin?error=' + encodeURIComponent('Tag not found'));
}
const tag = parseTagFile(file.text);
---

<AdminLayout title="edit tag">
  <div class="edit-tag-page">
    <a href="/admin/map" class="back">&larr; back</a>
    <h1>Edit: {tag.title}</h1>
    {error && <div class="msg error">{error}</div>}

    <p class="hint">Tap the map or drag the pin to adjust the spot.</p>
    <div class="search-wrap">
      <div class="search-row">
        <input id="location-search" type="search" placeholder="Search for a place…" autocomplete="off" />
        <button type="button" id="search-btn">Go</button>
      </div>
      <ul id="search-results" hidden></ul>
    </div>
    <div id="pick-map"></div>

    <form method="POST" action="/admin/api/map" enctype="multipart/form-data">
      <input type="hidden" name="mode" value="update" />
      <input type="hidden" name="slug" value={slug} />
      <input type="hidden" name="pubDate" value={tag.pubDate} />
      <input type="hidden" name="existingImage" value={tag.image ?? ''} />
      <input type="hidden" id="lat" name="lat" value={tag.lat} />
      <input type="hidden" id="lng" name="lng" value={tag.lng} />

      <div class="field">
        <label for="title">Title</label>
        <input id="title" name="title" value={tag.title} required />
      </div>

      <div class="field">
        <label for="category">Category</label>
        <select id="category" name="category" required>
          {categories.map((c) => (
            <option value={c.id} selected={c.id === tag.category}>{c.emoji} {c.label}</option>
          ))}
        </select>
      </div>

      {tag.image && (
        <div class="field">
          <label>Current photo</label>
          <img class="current-img" src={tagImageUrl(tag.image)} alt={tag.title} />
          <label class="checkbox-label">
            <input type="checkbox" name="removeImage" value="true" />
            Remove photo
          </label>
        </div>
      )}

      <div class="field">
        <label for="image">Replace photo <span class="optional">(optional)</span></label>
        <input id="image" name="image" type="file" accept="image/*" />
      </div>

      <div class="field">
        <label for="notes">Notes <span class="optional">(optional)</span></label>
        <textarea id="notes" name="notes">{tag.notes}</textarea>
      </div>

      <button type="submit" class="save-btn">Save changes</button>
    </form>
  </div>

  <script is:inline define:vars={{ start: { lat: tag.lat, lng: tag.lng } }}>
    (function () {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      s.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
      s.crossOrigin = '';
      s.onload = function () {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
        link.integrity = 'sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=';
        link.crossOrigin = '';
        document.head.appendChild(link);

        delete L.Icon.Default.prototype._getIconUrl;
        L.Icon.Default.mergeOptions({
          iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
          iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
          shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
        });

        const latInput = document.getElementById('lat');
        const lngInput = document.getElementById('lng');

        const map = L.map('pick-map').setView([start.lat, start.lng], 16);
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 19,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
          referrerPolicy: 'origin',
        }).addTo(map);

        const marker = L.marker([start.lat, start.lng], { draggable: true }).addTo(map);

        function sync(latlng) {
          latInput.value = latlng.lat.toFixed(6);
          lngInput.value = latlng.lng.toFixed(6);
        }
        marker.on('dragend', () => sync(marker.getLatLng()));
        map.on('click', (e) => { marker.setLatLng(e.latlng); sync(e.latlng); });

        const searchInput = document.getElementById('location-search');
        const searchBtn = document.getElementById('search-btn');
        const searchResults = document.getElementById('search-results');

        async function doSearch() {
          const q = searchInput.value.trim();
          if (!q) return;
          searchResults.innerHTML = '<li class="loading">Searching…</li>';
          searchResults.hidden = false;
          try {
            const res = await fetch(
              'https://nominatim.openstreetmap.org/search?format=json&limit=5&q=' + encodeURIComponent(q),
              { headers: { 'Accept-Language': 'en' } }
            );
            const items = await res.json();
            searchResults.innerHTML = '';
            if (!items.length) {
              searchResults.innerHTML = '<li class="no-results">No results</li>';
              return;
            }
            for (const item of items) {
              const li = document.createElement('li');
              li.textContent = item.display_name;
              li.addEventListener('click', () => {
                const latlng = L.latLng(parseFloat(item.lat), parseFloat(item.lon));
                map.setView(latlng, 16);
                marker.setLatLng(latlng);
                sync(latlng);
                searchResults.hidden = true;
                searchInput.value = '';
              });
              searchResults.appendChild(li);
            }
          } catch {
            searchResults.innerHTML = '<li class="no-results">Search failed</li>';
          }
        }

        searchBtn.addEventListener('click', doSearch);
        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') { e.preventDefault(); doSearch(); }
        });
        document.addEventListener('click', (e) => {
          if (!e.target.closest('.search-wrap')) searchResults.hidden = true;
        });
      };
      document.head.appendChild(s);
    })();
  </script>
</AdminLayout>

<style>
  .edit-tag-page {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem 0 3rem;
  }

  .back {
    font-size: 0.85rem;
    color: #6cf;
    text-decoration: none;
  }

  .back:hover {
    text-decoration: underline;
  }

  h1 {
    font-size: 1.2rem;
    margin: 0;
    word-break: break-word;
  }

  .hint {
    font-size: 0.78rem;
    color: #888;
    margin: 0;
  }

  .search-wrap {
    position: relative;
    z-index: 2000;
  }

  .search-row {
    display: flex;
    gap: 0.5rem;
  }

  #location-search {
    flex: 1;
  }

  #search-btn {
    font: inherit;
    font-size: 0.85rem;
    color: #2337ff;
    background: transparent;
    border: 1px solid #2337ff;
    padding: 0.35rem 0.75rem;
    border-radius: 4px;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  #search-btn:hover {
    background-color: #2337ff;
    color: #000;
  }

  #search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 1000;
    list-style: none;
    margin: 0.25rem 0 0;
    padding: 0;
    background: #1b1b1b;
    border: 1px solid #444;
    border-radius: 4px;
    max-height: 12rem;
    overflow-y: auto;
  }

  :global(#search-results li) {
    padding: 0.65rem 0.75rem;
    font-size: 0.82rem;
    color: #eee;
    cursor: pointer;
    border-bottom: 1px solid #333;
  }

  :global(#search-results li:last-child) {
    border-bottom: none;
  }

  :global(#search-results li:hover) {
    background: #2337ff;
    color: #000;
  }

  :global(#search-results .no-results),
  :global(#search-results .loading) {
    color: #888;
    cursor: default;
  }

  :global(#search-results .no-results:hover),
  :global(#search-results .loading:hover) {
    background: transparent;
    color: #888;
  }

  #pick-map {
    height: 45vh;
    border-radius: 4px;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  label {
    font-size: 0.78rem;
    color: #888;
    letter-spacing: 0.04em;
  }

  input,
  select,
  textarea {
    width: 100%;
    box-sizing: border-box;
    background: #1b1b1b;
    color: #eee;
    border: 1px solid #444;
    border-radius: 4px;
    padding: 0.5rem;
    font: inherit;
    font-size: 0.9rem;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: #2337ff;
  }

  textarea {
    line-height: 1.6;
    resize: vertical;
    min-height: 8rem;
    field-sizing: content;
  }

  .current-img {
    max-width: 160px;
    border-radius: 4px;
    border: none;
    padding: 0;
    background: none;
  }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: #bbb;
    cursor: pointer;
    letter-spacing: normal;
  }

  .checkbox-label input[type='checkbox'] {
    width: auto;
    accent-color: #2337ff;
  }

  .optional {
    color: #555;
    font-weight: normal;
  }

  .save-btn {
    font: inherit;
    font-size: 0.85rem;
    color: #2337ff;
    background: transparent;
    border: 1px solid #2337ff;
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    cursor: pointer;
    align-self: flex-start;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .save-btn:hover {
    background-color: #2337ff;
    color: #000;
  }

  @media (max-width: 480px) {
    .save-btn {
      align-self: stretch;
    }
  }
</style>
