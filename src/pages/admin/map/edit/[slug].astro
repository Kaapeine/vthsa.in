---
import AdminLayout from '../../../../layouts/AdminLayout.astro';
import { isAuthenticated } from '../../../../lib/auth';
import { getFile } from '../../../../lib/github';
import { isValidSlug } from '../../../../lib/content';
import { parseTagFile, tagImageUrl, tagPath } from '../../../../lib/map';
import { categories } from '../../../../lib/categories';

export const prerender = false;

if (!isAuthenticated(Astro.request.headers.get('cookie'))) {
  return Astro.redirect('/admin');
}

const { slug } = Astro.params;
if (!slug || !isValidSlug(slug)) {
  return Astro.redirect('/admin?error=' + encodeURIComponent('Invalid tag slug'));
}
const error = Astro.url.searchParams.get('error');

const file = await getFile(tagPath(slug));
if (!file) {
  return Astro.redirect('/admin?error=' + encodeURIComponent('Tag not found'));
}
const tag = parseTagFile(file.text);
---

<AdminLayout title="edit tag">
  <div class="edit-tag-page">
    <a href="/admin/map" class="back">&larr; back</a>
    <h1>Edit: {tag.title}</h1>
    {error && <div class="msg error">{error}</div>}

    <p class="hint">Tap the map or drag the pin to adjust the spot.</p>
    <div id="pick-map"></div>

    <form method="POST" action="/admin/api/map" enctype="multipart/form-data">
      <input type="hidden" name="mode" value="update" />
      <input type="hidden" name="slug" value={slug} />
      <input type="hidden" name="pubDate" value={tag.pubDate} />
      <input type="hidden" name="existingImage" value={tag.image ?? ''} />
      <input type="hidden" id="lat" name="lat" value={tag.lat} />
      <input type="hidden" id="lng" name="lng" value={tag.lng} />

      <div class="field">
        <label for="title">Title</label>
        <input id="title" name="title" value={tag.title} required />
      </div>

      <div class="field">
        <label for="category">Category</label>
        <select id="category" name="category" required>
          {categories.map((c) => (
            <option value={c.id} selected={c.id === tag.category}>{c.emoji} {c.label}</option>
          ))}
        </select>
      </div>

      {tag.image && (
        <div class="field">
          <label>Current photo</label>
          <img class="current-img" src={tagImageUrl(tag.image)} alt={tag.title} />
        </div>
      )}

      <div class="field">
        <label for="image">Replace photo <span class="optional">(optional)</span></label>
        <input id="image" name="image" type="file" accept="image/*" capture="environment" />
      </div>

      <div class="field">
        <label for="notes">Notes <span class="optional">(optional)</span></label>
        <textarea id="notes" name="notes">{tag.notes}</textarea>
      </div>

      <button type="submit" class="save-btn">Save changes</button>
    </form>
  </div>

  <script is:inline define:vars={{ start: { lat: tag.lat, lng: tag.lng } }}>
    (function () {
      const s = document.createElement('script');
      s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      s.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
      s.crossOrigin = '';
      s.onload = function () {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
        link.integrity = 'sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=';
        link.crossOrigin = '';
        document.head.appendChild(link);

        delete L.Icon.Default.prototype._getIconUrl;
        L.Icon.Default.mergeOptions({
          iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
          iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
          shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
        });

        const latInput = document.getElementById('lat');
        const lngInput = document.getElementById('lng');

        const map = L.map('pick-map').setView([start.lat, start.lng], 16);
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
          maxZoom: 19,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
          referrerPolicy: 'origin',
        }).addTo(map);

        const marker = L.marker([start.lat, start.lng], { draggable: true }).addTo(map);

        function sync(latlng) {
          latInput.value = latlng.lat.toFixed(6);
          lngInput.value = latlng.lng.toFixed(6);
        }
        marker.on('dragend', () => sync(marker.getLatLng()));
        map.on('click', (e) => { marker.setLatLng(e.latlng); sync(e.latlng); });
      };
      document.head.appendChild(s);
    })();
  </script>
</AdminLayout>

<style>
  .edit-tag-page {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.5rem 0 3rem;
  }

  .back {
    font-size: 0.85rem;
    color: #6cf;
    text-decoration: none;
  }

  .back:hover {
    text-decoration: underline;
  }

  h1 {
    font-size: 1.2rem;
    margin: 0;
    word-break: break-word;
  }

  .hint {
    font-size: 0.78rem;
    color: #888;
    margin: 0;
  }

  #pick-map {
    height: 45vh;
    border-radius: 4px;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    width: 100%;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  label {
    font-size: 0.78rem;
    color: #888;
    letter-spacing: 0.04em;
  }

  input,
  select,
  textarea {
    width: 100%;
    box-sizing: border-box;
    background: #1b1b1b;
    color: #eee;
    border: 1px solid #444;
    border-radius: 4px;
    padding: 0.5rem;
    font: inherit;
    font-size: 0.9rem;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: #2337ff;
  }

  textarea {
    line-height: 1.6;
    resize: vertical;
    min-height: 8rem;
    field-sizing: content;
  }

  .current-img {
    max-width: 160px;
    border-radius: 4px;
    border: none;
    padding: 0;
    background: none;
  }

  .optional {
    color: #555;
    font-weight: normal;
  }

  .save-btn {
    font: inherit;
    font-size: 0.85rem;
    color: #2337ff;
    background: transparent;
    border: 1px solid #2337ff;
    padding: 0.35rem 0.85rem;
    border-radius: 4px;
    cursor: pointer;
    align-self: flex-start;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .save-btn:hover {
    background-color: #2337ff;
    color: #000;
  }

  @media (max-width: 480px) {
    .save-btn {
      align-self: stretch;
    }
  }
</style>
