<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" />
    <title>OG Preview</title>
  </head>
  <body>
    <main>
      <div id="hero"></div>
      <div class="hero-content">
        <h1>Flow Field</h1>
      </div>
    </main>
  </body>
</html>

<script is:inline>
  const _p5Script = document.createElement('script');
  _p5Script.src = 'https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.11.3/p5.min.js';
  _p5Script.onload = function () {
    new p5(function (p) {
      const COUNT = 300;
      const NOISE_SCALE = 0.003;
      let particles = [];

      class Particle {
        constructor() { this.respawn(true); }
        respawn(anywhere) {
          this.x = p.random(p.width);
          this.y = anywhere ? p.random(p.height) : p.random(p.height);
          this.px = this.x; this.py = this.y;
          this.speed = p.random(1, 2.5);
          this.hue = p.random(220, 240);
          this.life = p.random(120, 320);
          this.maxLife = this.life;
        }
        update() {
          this.px = this.x; this.py = this.y;
          const angle = p.noise(this.x * NOISE_SCALE, this.y * NOISE_SCALE, p.frameCount * 0.004) * p.TWO_PI * 2;
          this.x += p.cos(angle) * this.speed;
          this.y += p.sin(angle) * this.speed;
          this.life--;
          if (this.life <= 0 || this.x < 0 || this.x > p.width || this.y < 0 || this.y > p.height) this.respawn(false);
        }
        draw() {
          const alpha = (this.life / this.maxLife) * 100;
          p.stroke(this.hue, 86, 100, alpha);
          p.strokeWeight(1.2);
          p.line(this.px, this.py, this.x, this.y);
        }
      }

      p.setup = function () {
        const hero = document.getElementById('hero');
        const cnv = p.createCanvas(hero.clientWidth, hero.clientHeight);
        cnv.parent('hero');
        p.colorMode(p.HSB, 360, 100, 100, 100);
        p.background(0, 0, 6);
        for (let i = 0; i < COUNT; i++) particles.push(new Particle());
      };

      p.draw = function () {
        p.background(0, 0, 6, 2);
        for (const pt of particles) { pt.update(); pt.draw(); }
      };
    });
  };
  document.head.appendChild(_p5Script);
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    height: 100%;
    background: black;
  }

  main {
    position: relative;
    min-height: 100vh;
    width: 100%;
  }

  #hero {
    position: absolute;
    inset: 0;
    background: rgb(0 0 6);
    overflow: hidden;
  }

  #hero canvas {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
  }

  .hero-content {
    position: absolute;
    z-index: 1;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 80%;
    height: 90%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.7);
    border-radius: 10px;
    border: 1px solid #000d8a;
  }

  h1 {
    font-family: 'Space Mono', monospace;
    color: #fff;
    font-size: 8vw;
    font-weight: 700;
    margin: 0;
    line-height: 1;
    letter-spacing: -0.02em;
    text-align: center;
  }
</style>
