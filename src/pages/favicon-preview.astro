<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Favicon Preview</title>
  </head>
  <body>
    <div id="canvas-wrap"></div>
    <button id="download">Download PNG</button>
  </body>
</html>

<script is:inline>
  const SIZE = 512;

  const _p5Script = document.createElement('script');
  _p5Script.src = 'https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.11.3/p5.min.js';
  _p5Script.onload = function () {
    new p5(function (p) {
      const COUNT = 100;
      const NOISE_SCALE = 0.01;
      let particles = [];

      class Particle {
        constructor() { this.respawn(true); }
        respawn(anywhere) {
          this.x = p.random(p.width);
          this.y = anywhere ? p.random(p.height) : p.random(p.height);
          this.px = this.x; this.py = this.y;
          this.speed = p.random(1, 2.5);
          this.hue = p.random(220, 240);
          this.life = p.random(120, 320);
          this.maxLife = this.life;
        }
        update() {
          this.px = this.x; this.py = this.y;
          const angle = p.noise(this.x * NOISE_SCALE, this.y * NOISE_SCALE, p.frameCount * 0.004) * p.TWO_PI * 2;
          this.x += p.cos(angle) * this.speed;
          this.y += p.sin(angle) * this.speed;
          this.life--;
          if (this.life <= 0 || this.x < 0 || this.x > p.width || this.y < 0 || this.y > p.height) this.respawn(false);
        }
        draw() {
          const alpha = (this.life / this.maxLife) * 100;
          p.stroke(this.hue, 86, 100, 100);
          p.strokeWeight(5);
          p.line(this.px, this.py, this.x, this.y);
        }
      }

      p.setup = function () {
        const cnv = p.createCanvas(SIZE, SIZE);
        cnv.parent('canvas-wrap');
        p.colorMode(p.HSB, 360, 100, 100, 100);
        p.background(0, 0, 6);
        for (let i = 0; i < COUNT; i++) particles.push(new Particle());
      };

      p.draw = function () {
        p.background(0, 0, 6, 1);
        for (const pt of particles) { pt.update(); pt.draw(); }
      };
    });
  };
  document.head.appendChild(_p5Script);

  document.getElementById('download').addEventListener('click', () => {
    const src = document.querySelector('#canvas-wrap canvas');

    const out = document.createElement('canvas');
    out.width = src.width;
    out.height = src.height;
    const ctx = out.getContext('2d');

    const r = src.width / 2;
    ctx.beginPath();
    ctx.arc(r, r, r, 0, Math.PI * 2);
    ctx.closePath();
    ctx.clip();
    ctx.drawImage(src, 0, 0);

    const a = document.createElement('a');
    a.download = 'favicon.png';
    a.href = out.toDataURL('image/png');
    a.click();
  });
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; }

  body {
    margin: 0;
    background: #111;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    gap: 2rem;
  }

  #canvas-wrap {
    width: 512px;
    height: 512px;
    border-radius: 50%;
    overflow: hidden;
  }

  #canvas-wrap canvas {
    display: block;
  }

  button {
    font-family: monospace;
    font-size: 1rem;
    padding: 0.6rem 1.4rem;
    background: #2337ff;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
  }

  button:hover {
    background: #000d8a;
  }
</style>
