---
import { getCollection } from 'astro:content';
import { categories } from '../lib/categories';
import { tagImageUrl } from '../lib/map';
import { SITE_TITLE } from '../consts';
import '../styles/global.css';

const entries = await getCollection('map');
const tags = entries.map((e) => ({
  title: e.data.title,
  category: e.data.category,
  lat: e.data.lat,
  lng: e.data.lng,
  image: e.data.image ? tagImageUrl(e.data.image) : null,
  notes: e.body ?? '',
  date: e.data.pubDate.toISOString().slice(0, 10),
}));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Sightings · {SITE_TITLE}</title>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-F2JHBLXS0H"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-F2JHBLXS0H');
    </script>
  </head>
  <body>
    <header class="map-header">
      <div class="site-link">
        <a href="/">{SITE_TITLE}</a>
        <span class="sep">/</span>
        <a href="/sightings">Sightings</a>
      </div>
      <div class="controls">
        <button id="toggle-list" type="button">List</button>
        <button id="toggle-filter" type="button">Filter</button>
        <button id="toggle-legend" type="button">Legend</button>
      </div>
    </header>

    <div id="map"></div>

    <!-- Custom tag modal (replaces Leaflet popup) -->
    <div id="tag-backdrop" hidden></div>
    <div id="tag-modal" hidden>
      <button id="modal-close" type="button" aria-label="Close">✕</button>
      <img id="modal-img" src="" alt="" hidden />
      <div id="modal-body">
        <strong id="modal-title"></strong>
        <div id="modal-meta-row">
          <span id="modal-meta"></span>
          <span id="modal-coords"></span>
        </div>
        <p id="modal-notes" hidden></p>
      </div>
    </div>

    <!-- All-sightings list (same big-modal treatment as the tag detail) -->
    <div id="list-backdrop" hidden></div>
    <div id="list-modal" hidden>
      <button id="list-close" type="button" aria-label="Close">✕</button>
      <p class="modal-heading">All sightings</p>
      <div id="tag-list"></div>
    </div>

    <aside id="filter-panel" class="panel" hidden>
      <p class="panel-label">Filter</p>
      <div id="filter-list"></div>
    </aside>

    <aside id="legend-panel" class="panel" hidden>
      <p class="panel-label">Legend</p>
      <div id="legend-list"></div>
    </aside>

    <script id="map-data" type="application/json" set:html={JSON.stringify({ tags, categories })}></script>

    <script is:inline>
      (function () {
        // Load Leaflet CSS + JS dynamically so init is guaranteed to run after L is defined.
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
        link.integrity = 'sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=';
        link.crossOrigin = '';
        document.head.appendChild(link);

        const s = document.createElement('script');
        s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
        s.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
        s.crossOrigin = '';
        s.onload = initMap;
        document.head.appendChild(s);

        function escapeHtml(str) {
          return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
        }

        function initMap() {
          const { tags, categories } = JSON.parse(
            document.getElementById('map-data').textContent
          );
          const catById = Object.fromEntries(categories.map((c) => [c.id, c]));

          function iconFor(catId) {
            const c = catById[catId];
            return L.divIcon({
              className: 'emoji-marker',
              html: `<span>${c ? c.emoji : '📍'}</span>`,
              iconSize: [38, 38],
              iconAnchor: [19, 19],
              popupAnchor: [0, -18],
            });
          }

          const backdrop = document.getElementById('tag-backdrop');
          const modal = document.getElementById('tag-modal');
          const modalImg = document.getElementById('modal-img');
          const modalTitle = document.getElementById('modal-title');
          const modalMeta = document.getElementById('modal-meta');
          const modalCoords = document.getElementById('modal-coords');
          const modalNotes = document.getElementById('modal-notes');
          const modalClose = document.getElementById('modal-close');

          function openModal(t) {
            if (t.image) {
              modalImg.src = t.image;
              modalImg.alt = t.title;
              modalImg.hidden = false;
            } else {
              modalImg.hidden = true;
              modalImg.removeAttribute('src');
            }
            modalTitle.textContent = t.title;
            const cat = catById[t.category];
            modalMeta.textContent = `${cat ? cat.emoji : '📍'} ${cat ? cat.label : t.category} · ${t.date}`;
            modalCoords.textContent = `${t.lat.toFixed(4)}, ${t.lng.toFixed(4)}`;
            if (t.notes) {
              modalNotes.textContent = t.notes;
              modalNotes.hidden = false;
            } else {
              modalNotes.hidden = true;
            }
            backdrop.hidden = false;
            modal.hidden = false;
          }

          function closeModal() {
            backdrop.hidden = true;
            modal.hidden = true;
          }

          modalClose.addEventListener('click', closeModal);
          backdrop.addEventListener('click', closeModal);

          const map = L.map('map');
          L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
            referrerPolicy: 'origin',
          }).addTo(map);

          const groups = {};
          for (const c of categories) groups[c.id] = L.layerGroup().addTo(map);
          const uncategorized = L.layerGroup().addTo(map);

          const bounds = [];
          for (const t of tags) {
            const marker = L.marker([t.lat, t.lng], { icon: iconFor(t.category) });
            marker.on('click', () => openModal(t));
            (groups[t.category] || uncategorized).addLayer(marker);
            bounds.push([t.lat, t.lng]);
          }

          if (bounds.length > 0) {
            map.fitBounds(bounds, { padding: [40, 40], maxZoom: 16 });
          } else {
            map.setView([20, 0], 2);
          }

          // Filter — only show categories that have at least one tag.
          const usedCatIds = new Set(tags.map((t) => t.category));
          const filterList = document.getElementById('filter-list');
          for (const c of categories) {
            if (!usedCatIds.has(c.id)) continue;
            const row = document.createElement('label');
            row.className = 'filter-row';
            row.innerHTML = `<input type="checkbox" checked /> <span>${c.emoji} ${escapeHtml(c.label)}</span>`;
            const input = row.querySelector('input');
            input.addEventListener('change', () => {
              if (input.checked) map.addLayer(groups[c.id]);
              else map.removeLayer(groups[c.id]);
            });
            filterList.appendChild(row);
          }

          // Legend — all categories.
          const legendList = document.getElementById('legend-list');
          for (const c of categories) {
            const row = document.createElement('div');
            row.className = 'legend-row';
            row.innerHTML = `<span>${c.emoji}</span> <span>${escapeHtml(c.label)}</span>`;
            legendList.appendChild(row);
          }

          // Panel toggles — mutually exclusive. Buttons stay in their active
          // state while their panel is open.
          const filterPanel = document.getElementById('filter-panel');
          const legendPanel = document.getElementById('legend-panel');
          const filterBtn = document.getElementById('toggle-filter');
          const legendBtn = document.getElementById('toggle-legend');
          function syncActive() {
            filterBtn.classList.toggle('active', !filterPanel.hidden);
            legendBtn.classList.toggle('active', !legendPanel.hidden);
          }
          filterBtn.addEventListener('click', () => {
            legendPanel.hidden = true;
            filterPanel.hidden = !filterPanel.hidden;
            syncActive();
          });
          legendBtn.addEventListener('click', () => {
            filterPanel.hidden = true;
            legendPanel.hidden = !legendPanel.hidden;
            syncActive();
          });
          // Tapping/clicking outside an open panel (and outside its button)
          // closes it and clears the active state. The button's own handler
          // already covers clicks on the button itself.
          document.addEventListener('click', (e) => {
            if (filterPanel.hidden && legendPanel.hidden) return;
            const t = e.target;
            if (
              filterPanel.contains(t) ||
              legendPanel.contains(t) ||
              filterBtn.contains(t) ||
              legendBtn.contains(t)
            )
              return;
            filterPanel.hidden = true;
            legendPanel.hidden = true;
            syncActive();
          });

          // All-sightings list — newest first. Clicking an item recenters the
          // map on that tag and opens its detail modal.
          const listBackdrop = document.getElementById('list-backdrop');
          const listModal = document.getElementById('list-modal');
          const listClose = document.getElementById('list-close');
          const tagList = document.getElementById('tag-list');
          const sortedTags = [...tags].sort((a, b) => b.date.localeCompare(a.date));
          for (const t of sortedTags) {
            const cat = catById[t.category];
            const item = document.createElement('button');
            item.type = 'button';
            item.className = 'tag-list-item';
            item.innerHTML =
              `<span class="tag-list-emoji">${cat ? cat.emoji : '📍'}</span>` +
              `<span class="tag-list-text">` +
              `<span class="tag-list-title">${escapeHtml(t.title)}</span>` +
              `<span class="tag-list-date">${t.date}</span>` +
              `</span>`;
            item.addEventListener('click', () => {
              closeList();
              map.setView([t.lat, t.lng], Math.max(map.getZoom() || 0, 15));
              openModal(t);
            });
            tagList.appendChild(item);
          }
          function openList() {
            filterPanel.hidden = true;
            legendPanel.hidden = true;
            syncActive();
            listBackdrop.hidden = false;
            listModal.hidden = false;
          }
          function closeList() {
            listBackdrop.hidden = true;
            listModal.hidden = true;
          }
          document.getElementById('toggle-list').addEventListener('click', openList);
          listClose.addEventListener('click', closeList);
          listBackdrop.addEventListener('click', closeList);

          // Keep panels below the header regardless of its height.
          const header = document.querySelector('.map-header');
          function updatePanelTop() {
            const bottom = header.getBoundingClientRect().bottom + 8;
            filterPanel.style.top = bottom + 'px';
            legendPanel.style.top = bottom + 'px';
          }
          updatePanelTop();
          window.addEventListener('resize', updatePanelTop);
        }
      })();
    </script>
  </body>
</html>

<style is:global>
  .emoji-marker span {
    font-size: 1.8rem;
    line-height: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.6rem;
    height: 2.6rem;
    background: rgba(0, 0, 0, 0.75);
    border: 1.5px solid #2337ff;
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.6);
  }
  #tag-backdrop,
  #list-backdrop {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(0, 0, 0, 0.7);
  }
  #tag-backdrop[hidden],
  #tag-modal[hidden],
  #list-backdrop[hidden],
  #list-modal[hidden] {
    display: none !important;
  }
  #tag-modal,
  #list-modal {
    position: fixed;
    z-index: 2001;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90vw;
    max-width: 520px;
    /* widened on desktop via media query below */
    max-height: 80vh;
    background: #0a0a0a;
    border: 1px solid #333;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: 'Space Mono', monospace;
  }
  #modal-close,
  #list-close {
    position: absolute;
    top: 0.6rem;
    right: 0.75rem;
    z-index: 1;
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
    border: none;
    border-radius: 50%;
    width: 2rem;
    height: 2rem;
    font-size: 0.75rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #modal-img {
    width: 100%;
    height: auto;
    max-height: 55vh;
    /* contain (not cover) so the whole image is visible — scaled down to fit,
       never cropped — and looks identical on desktop and mobile. */
    object-fit: contain;
    display: block;
    flex-shrink: 0;
  }
  /* An ID selector's `display: block` above out-specifies the UA's
     `[hidden] { display: none }`, so hiding must be re-asserted here —
     otherwise a previous tag's image lingers on an image-less tag. */
  #modal-img[hidden] {
    display: none;
  }
  #modal-body {
    padding: 1rem 1.25rem 1.5rem;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  #modal-title {
    font-size: 1rem;
    color: #fff;
  }
  #modal-notes {
    font-size: 0.82rem;
    color: #aaa;
    line-height: 1.6;
    margin: 0;
    white-space: pre-wrap;
  }
  #modal-meta-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }
  #modal-meta {
    font-size: 0.75rem;
    color: #666;
  }
  #modal-coords {
    font-size: 0.72rem;
    color: #444;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  @media (min-width: 768px) {
    #tag-modal,
    #list-modal { max-width: 740px; }
  }

  /* All-sightings list modal */
  .modal-heading {
    margin: 0;
    padding: 1.1rem 1.25rem 0.6rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #666;
    flex-shrink: 0;
  }
  #tag-list {
    overflow-y: auto;
    padding: 0 0.5rem 0.75rem;
  }
  .tag-list-item {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    width: 100%;
    text-align: left;
    background: transparent;
    border: none;
    border-radius: 6px;
    padding: 0.55rem 0.75rem;
    cursor: pointer;
    color: #eee;
    font: inherit;
  }
  .tag-list-item:hover {
    background: rgba(255, 255, 255, 0.06);
  }
  .tag-list-emoji {
    font-size: 1.25rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .tag-list-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .tag-list-title {
    font-size: 0.85rem;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tag-list-date {
    font-size: 0.7rem;
    color: #666;
    font-variant-numeric: tabular-nums;
  }
</style>

<style>
  body {
    margin: 0;
    padding: 0;
    overflow: hidden;
  }
  .map-header {
    position: fixed;
    top: 0.6rem;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 2rem);
    max-width: 900px;
    z-index: 1000;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem;
    background: rgba(0, 0, 0, 0.92);
    border: 1px solid #222;
    border-radius: 8px;
    box-sizing: border-box;
  }
  @media (max-width: 480px) {
    .map-header {
      height: auto;
      padding: 0.6rem 1rem;
      flex-wrap: wrap;
      gap: 0.4rem;
    }
    .site-link {
      width: 100%;
    }
  }
  .site-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
  }
  .site-link a {
    color: #fff;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .site-link a:hover {
    color: var(--accent);
  }
  .sep {
    color: #444;
  }
  .controls {
    display: flex;
    gap: 0.5rem;
  }
  .controls button {
    font: inherit;
    font-size: 0.78rem;
    color: var(--accent);
    background: transparent;
    border: 1px solid var(--accent);
    border-radius: 4px;
    padding: 0.25rem 0.65rem;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease;
  }
  .controls button:hover,
  .controls button.active {
    background: var(--accent);
    color: #000;
  }
  #map {
    margin-top: 0;
    height: 100vh;
    width: 100%;
    z-index: 1;
  }
  .panel {
    position: fixed;
    right: 1rem;
    z-index: 1000;
    min-width: 11rem;
    max-width: 80vw;
    background: rgba(0, 0, 0, 0.93);
    border: 1px solid #333;
    border-radius: 4px;
    padding: 0.6rem 0.85rem 0.75rem;
  }
  @media (min-width: 918px) {
    .panel {
      right: calc((100vw - 900px) / 2);
    }
  }
  .panel-label {
    font-size: 0.7rem;
    color: #666;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 0.4rem;
  }
  #filter-list,
  #legend-list {
    display: flex;
    flex-direction: column;
  }
  .filter-row,
  .legend-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.2rem 0;
    font-size: 0.82rem;
    cursor: pointer;
    color: #eee;
  }
  .filter-row input[type='checkbox'] {
    accent-color: var(--accent);
  }
</style>
