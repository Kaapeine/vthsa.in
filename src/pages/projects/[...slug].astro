---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects
    .filter((project) => !project.data.onlyLink)
    .map((project) => ({
      params: { slug: project.id },
      props: project,
    }));
}
type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await render(project);
const { title, description, externalUrl, date, tags } = project.data;
---

<BaseLayout title={title} description={description}>
  <article>
    <div class="prose">
      <div class="header">
        <h1>{title}</h1>
        <div class="meta">
          <FormattedDate date={date} />
          {tags?.map((tag) => <span class="tag">#{tag}</span>)}
        </div>
        <p class="description">{description}</p>
        <a
          href={externalUrl}
          class="external-link"
          target="_blank"
          rel="noopener noreferrer"
        >
          View Project →
        </a>
      </div>
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .prose {
    width: 100%;
    margin: auto;
    padding: 1em;
  }
  .header {
    margin-bottom: 1.5em;
    padding-bottom: 1em;
  }
  h1 {
    margin: 0 0 0.4em 0;
  }
  .meta {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    font-size: 0.78em;
    color: rgb(var(--gray));
    margin-bottom: 0.75em;
  }
  .tag {
    color: var(--accent);
    letter-spacing: 0.03em;
  }
  .description {
    color: rgb(var(--gray));
    font-size: 0.9em;
    margin: 0 0 0.75em 0;
  }
  .external-link {
    font-size: 0.85em;
    color: var(--accent);
    text-decoration: none;
  }
  .external-link:hover {
    text-decoration: underline;
  }
</style>
