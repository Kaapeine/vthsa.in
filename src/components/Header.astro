---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
  <nav>
    <h2>
      <a href="/">{SITE_TITLE}</a><span id="section-sep" class="section-sep" hidden> / </span><a id="section-link" class="section-link" href="" hidden></a>
    </h2>
    <div class="internal-links">
      <HeaderLink href="/writing">Writing</HeaderLink>
      <HeaderLink href="/projects">Projects</HeaderLink>
      <HeaderLink href="/library">Library</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <div class="more-menu">
        <button id="more-btn" class="more-btn" aria-haspopup="true" aria-expanded="false" aria-label="More">+</button>
        <div id="more-dropdown" class="more-dropdown">
          <HeaderLink href="/music">Music</HeaderLink>
          <HeaderLink href="/sightings">Sightings</HeaderLink>
          <HeaderLink href="/toys">Toys</HeaderLink>
        </div>
      </div>
      <a
        href="https://github.com/Kaapeine"
        target="_blank"
        rel="noopener noreferrer"
        class="github-link"
        aria-label="GitHub"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
      </a>
    </div>
  </nav>
</header>

<script>
  const sections: Record<string, string> = {
    writing: 'Writing',
    projects: 'Projects',
    library: 'Library',
    about: 'About',
    music: 'Music',
    sightings: 'Sightings',
    toys: 'Toys',
    resume: 'Resume',
  };

  function updateSection() {
    const link = document.getElementById('section-link') as HTMLAnchorElement;
    if (!link) return;
    const segment = location.pathname.split('/').filter(Boolean)[0] ?? '';
    const label = sections[segment];
    const sep = document.getElementById('section-sep') as HTMLSpanElement;
    if (label) {
      link.textContent = label;
      link.href = `/${segment}`;
      link.hidden = false;
      sep.hidden = false;
    } else {
      link.hidden = true;
      sep.hidden = true;
    }
  }

  let controller: AbortController | null = null;

  document.addEventListener('astro:page-load', () => {
    updateSection();
    controller?.abort();
    controller = new AbortController();
    const { signal } = controller;

    const btn = document.getElementById('more-btn') as HTMLButtonElement;
    const dropdown = document.getElementById('more-dropdown') as HTMLDivElement;
    if (!btn || !dropdown) return;

    function close() {
      dropdown.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = dropdown.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(isOpen));
    }, { signal });

    dropdown.querySelectorAll('a').forEach((a) => {
      a.addEventListener('click', close, { signal });
    });

    document.addEventListener('click', (e) => {
      if (dropdown.classList.contains('open') && !dropdown.contains(e.target as Node)) close();
    }, { signal });

    document.addEventListener('astro:before-preparation', close, { signal });
  });
</script>

<style>
  header {
    margin: 0;
    padding: 1em;
    box-shadow: 0 2px 8px rgba(var(--black), 5%);
    width: 100%;
  }
  h2 {
    margin: 0;
    font-size: 1.5em;
  }

  h2 a {
    text-decoration: none;
    color: #fff;
  }
  h2 a:hover {
    text-decoration: underline 2px var(--accent);
    text-underline-offset: 5px;
  }
  .section-sep,
  .section-link {
    font-size: 0.65em;
    font-weight: 400;
  }
  .section-sep {
    color: #fff;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  nav a {
    padding: 0.5em 0.5em;
    color: #fff;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  nav a:hover:not(.github-link) {
    text-decoration: underline 2px var(--accent);
    text-underline-offset: 5px;
  }
  .internal-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5em;
  }
  .github-link {
    display: flex;
    align-items: center;
    padding: 0.5em 0.5em;
    color: #fff;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .github-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .more-menu {
    position: relative;
  }
  .more-btn {
    background: none;
    border: none;
    font: inherit;
    font-size: 1.4em;
    line-height: 1;
    color: #fff;
    cursor: pointer;
    padding: 0.2em 0.4em;
    transition: color 0.2s ease;
  }
  .more-btn:hover {
    color: var(--accent);
  }
  .more-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 0.25rem);
    right: 0;
    background: rgba(0, 0, 0, 0.95);
    border: 1px solid var(--accent-dark);
    border-radius: 6px;
    flex-direction: column;
    min-width: 8rem;
    z-index: 100;
    padding: 0.25rem 0;
  }
  .more-dropdown.open {
    display: flex;
  }
  .more-dropdown a {
    padding: 0.5em 1em;
    white-space: nowrap;
  }

  .social-links,
  .social-links a {
    display: flex;
  }
  @media (max-width: 480px) {
    nav {
      flex-direction: column;
      align-items: flex-start;
    }
    .internal-links {
      gap: 0;
    }
    nav a {
      padding: 0.3em 0.4em;
      font-size: 0.9em;
    }
    .social-links {
      display: none;
    }
  }
</style>
